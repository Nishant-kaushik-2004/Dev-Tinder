{
  "rewrites": [
    {
      "source": "/socket.io/:path*",
      "destination": "https://devtinder-api.duckdns.org/socket.io/:path*"
    },
    {
      "source": "/api/:path*",
      "destination": "https://devtinder-api.duckdns.org/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}